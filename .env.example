# OpenAI-compatible API configuration for Claude
# Copy this file to .env and fill in your actual values

# API Key for Claude access (via OpenAI-compatible endpoint)
OPENAI_API_KEY=your_api_key_here

# Base URL for Claude API (OpenAI-compatible)
OPENAI_BASE_URL=https://llm.aibricks.io/v1

# Model name (e.g., claude-opus, claude-sonnet)
MODEL_NAME=claude-opus

# AWS Region (if using Bedrock)
AWS_REGION=us-east-1

# Optional: LangSmith tracing configuration
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=research-intelligence-assistant
LANGSMITH_TRACING_V2=false

# Optional: Workspace directory (defaults to ~/.ria)
RIA_WORKSPACE_DIR=

# Optional: Enable live integration tests (set to 1 to enable)
RIA_RUN_LIVE_TESTS=0

# SerpAPI configuration for patent search
SERPAPI_API_KEY=your_serpapi_key_here
